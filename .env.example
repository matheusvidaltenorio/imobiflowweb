# ==========================================
# BACKEND (.env na pasta backend/)
# ==========================================

# Banco de dados — OBRIGATÓRIO antes do backend subir:
#
# Opção A (recomendado local): na RAIZ do repo rode: docker compose up -d
# O Postgres fica em localhost:5433 (veja docker-compose.yml: mapeia 5433 -> 5432).
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/imobflow?schema=public"
#
# Opção B: Supabase — cole a URI completa (geralmente porta 5432 no host remoto).
# DATABASE_URL="postgresql://postgres.xxx:senha@aws-0-...pooler.supabase.com:6543/postgres?pgbouncer=true"

# JWT
JWT_SECRET="sua-chave-secreta-jwt-muito-longa-e-segura"
REFRESH_SECRET="sua-chave-secreta-refresh-muito-longa"

# Cloudinary (upload de imagens)
CLOUDINARY_CLOUD_NAME="seu_cloud_name"
CLOUDINARY_API_KEY="sua_api_key"
CLOUDINARY_API_SECRET="seu_api_secret"

# Google Maps (opcional)
GOOGLE_MAPS_API_KEY="sua_api_key"

# URL do frontend (para CORS)
FRONTEND_URL="http://localhost:3000"

# Porta do servidor
PORT=3333

# ==========================================
# FRONTEND (.env.local na pasta frontend/)
# ==========================================

# URL da API
NEXT_PUBLIC_API_URL="http://localhost:3333/api"
