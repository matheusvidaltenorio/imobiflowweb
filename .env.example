# =============================================================================
# ImobiFlow — variáveis de ambiente (TEMPLATE — sem segredos reais)
# =============================================================================
# Copie os blocos para:
#   - backend/.env
#   - frontend/.env.local
# Valores reais NUNCA devem ir para o Git. Gere JWT_SECRET forte em produção.
# =============================================================================

# --- BACKEND (pasta backend/.env) ---

# PostgreSQL — obrigatório. Exemplo local com Docker na raiz: porta 5433 (veja docker-compose.yml)
DATABASE_URL=

JWT_SECRET=
REFRESH_SECRET=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Maps — backend: Geocoding API (salvar lat/lng a partir do endereço). Restrinja por IP do servidor.
GOOGLE_MAPS_API_KEY=

# Opcional — Map ID (vetorial / marcadores avançados). Crie em Google Cloud Console → Map Management.
GOOGLE_MAPS_MAP_ID=
GOOGLE_MAPS_DEFAULT_LAT=-14.235
GOOGLE_MAPS_DEFAULT_LNG=-51.9253

# CORS: URL(s) do frontend em produção, separadas por vírgula se várias
FRONTEND_URL=

PORT=3333

# Opcional — e-mail (recuperação de senha)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- FRONTEND (pasta frontend/.env.local) ---

NEXT_PUBLIC_API_URL=
# Google Maps — frontend: Maps JavaScript API. Restrinja por referenciadores HTTP (localhost:3002, domínio de produção).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Opcional — mesmo Map ID do backend, se usar mapa vetorial no cliente.
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
NEXT_PUBLIC_GOOGLE_MAPS_DEFAULT_LAT=-14.235
NEXT_PUBLIC_GOOGLE_MAPS_DEFAULT_LNG=-51.9253
