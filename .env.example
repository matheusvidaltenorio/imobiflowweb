# =============================================================================
# ImobiFlow — variáveis de ambiente (TEMPLATE — sem segredos reais)
# =============================================================================
# Copie os blocos para:
#   - backend/.env
#   - frontend/.env.local
# Valores reais NUNCA devem ir para o Git. Gere JWT_SECRET forte em produção.
# =============================================================================

# --- BACKEND (pasta backend/.env) ---

# PostgreSQL — obrigatório. Exemplo local com Docker na raiz: porta 5433 (veja docker-compose.yml)
DATABASE_URL=

JWT_SECRET=
REFRESH_SECRET=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Opcional — Google Geocoding API no backend. Se ausente, geocoding usa Nominatim (OSM). Mapas no app = MapLibre.
GOOGLE_MAPS_API_KEY=

# CORS: URL(s) do frontend em produção, separadas por vírgula se várias
FRONTEND_URL=

PORT=3333

# Opcional — e-mail (recuperação de senha)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- FRONTEND (pasta frontend/.env.local) ---

NEXT_PUBLIC_API_URL=

# MapLibre — tiles/estilo (URL de style JSON). Padrão CARTO Positron sem chave.
# NEXT_PUBLIC_MAP_STYLE_URL=
NEXT_PUBLIC_MAP_DEFAULT_LAT=-14.235
NEXT_PUBLIC_MAP_DEFAULT_LNG=-51.9253
NEXT_PUBLIC_MAP_DEFAULT_ZOOM=5
