# --- Dependências ---
node_modules/

# --- Builds & artefatos ---
dist/
build/
out/
.next/
*.tsbuildinfo
frontend/.next/
frontend/out/
backend/dist/

# --- Variáveis de ambiente (nunca commitar segredos) ---
.env
.env.local
.env.production
.env.development
.env.test
.env.*.local
# Permitir apenas templates versionados:
!.env.example
!backend/.env.example
!frontend/.env.example

# --- Logs & cache ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.cache/
.turbo/
.eslintcache

# --- Testes & cobertura ---
coverage/
.nyc_output/

# --- Banco local / dumps ad-hoc (não confundir com prisma/migrations/*.sql) ---
*.db
*.db-journal
*.dump
**/db-dumps/
**/backups/*.sql

# --- Uploads locais (se criados em runtime) ---
uploads/
**/public/uploads/

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo

# --- SO ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Certificados & chaves ---
*.pem
*.p12
*.key
!**/*.key.ts

# --- Deploy / ferramentas ---
.vercel
.netlify

# --- Temporários ---
*.tmp
*.temp
*~
