# Copie para backend/.env — não commite o .env preenchido.

# PostgreSQL (obrigatório). Com Docker na raiz: docker compose up -d → use porta 5433 no host
# Confirme que aponta para o MESMO banco que a API usa (host, porta, database, schema).
# Campanhas (marketing_campaigns, campaign_*, ai_image_generation_jobs) exigem migration aplicada:
#   npm run db:deploy
# ou: npx prisma migrate deploy && npx prisma generate
DATABASE_URL=

JWT_SECRET=
REFRESH_SECRET=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Opcional: Google Geocoding. Se vazio, geocoding usa Nominatim (OSM). Mapas no frontend = MapLibre.
GOOGLE_MAPS_API_KEY=

# Opcional: Google Gemini (texto/imagem). Coloque APENAS em backend/.env local — nunca commite a chave.
# Se a chave vazou em algum lugar, revogue e crie outra em https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Modelo para refinamento de copy (padrão gemini-2.0-flash). Ver modelos em https://ai.google.dev/gemini-api/docs/models
# GEMINI_MODEL=gemini-2.0-flash

# Rotas para tempos de deslocamento (POIs). Padrão: OSRM público (uso moderado). Self-host recomendado em produção.
# OSRM_BASE_URL=https://router.project-osrm.org

# Overpass API para “atualizar serviços próximos”. Padrão: overpass-api.de (uso moderado; instância própria em produção).
# OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# Produção: URL exata do site (CORS). Dev: qualquer localhost é aceito pelo backend.
FRONTEND_URL=

# Meta (Facebook Login + Instagram Business via página). Deve ser IDÊNTICO ao "Valid OAuth Redirect URIs" no app Meta.
# Inclua o prefixo global da API: /api/... (ex.: ngrok ou URL pública do backend).
# Exemplo dev com túnel: https://SEU_SUBDOMINIO.ngrok-free.dev/api/social/meta/callback
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT_URI=
# Escopos OAuth (opcional). Se definido, substitui minimal/extended (lista separada por vírgula).
# Ex.: public_profile,email,pages_show_list
# META_OAUTH_SCOPES=
# Sem META_OAUTH_SCOPES: META_OAUTH_SCOPE_MODE=minimal | extended — ou use GET /social/meta/connect?scope=extended
# META_OAUTH_SCOPE_MODE=minimal
# Opcional: mesma versão em dialog/oauth e Graph (padrão v18.0)
# META_GRAPH_VERSION=v18.0
# Criptografia de tokens no banco (64 caracteres hex = 32 bytes). Altamente recomendado em produção.
# SOCIAL_TOKEN_ENCRYPTION_KEY=

PORT=3333

RESEND_API_KEY=
RESEND_FROM_EMAIL=
