  socialConnection   SocialConnection? @relation(fields: [socialConnectionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([campaignId])
  @@index([createdAt])
  @@map("social_integration_logs")
}

model CampaignCopy {
