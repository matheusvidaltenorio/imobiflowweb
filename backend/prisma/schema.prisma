  brokerUserId String
  leadId       String?
  clientId     String?
  title        String
  message      String?            @db.Text
  shareToken   String             @unique @default(cuid())
  status       CatalogShareStatus @default(DRAFT)
  sentAt       DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  broker User    @relation(fields: [brokerUserId], references: [id], onDelete: Cascade)
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items  CatalogShareItem[]

  @@index([brokerUserId])
  @@index([leadId])
}

model CatalogShareItem {
  id             String   @id @default(cuid())
  catalogShareId String
  sortOrder      Int      @default(0)
  lotId          String?
  propertyId     String?
  brokerNote     String?

  catalogShare CatalogShare @relation(fields: [catalogShareId], references: [id], onDelete: Cascade)

  @@index([catalogShareId])
}

/// Publicação unificada em portais (conectores plugáveis).
model PortalListing {
  id                  String                         @id @default(cuid())
  lotId               String?
  propertyId          String?
  portal              PortalCode
  externalListingId   String?
  listingStatus       String?
  publicationStatus   PortalListingLifecycleStatus   @default(DRAFT)
  title               String?
  description         String?                        @db.Text
  price               Decimal?                       @db.Decimal(18, 2)
  imagesSnapshot      Json?
  payloadSnapshot     Json?
  lastSyncAt          DateTime?
  lastError           String?                        @db.Text
  publishedAt         DateTime?
  unpublishedAt       DateTime?
  createdById         String
  createdAt           DateTime                       @default(now())
  updatedAt           DateTime                       @updatedAt

  lot       Lot?      @relation(fields: [lotId], references: [id], onDelete: Cascade)
  property  Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdBy User      @relation("PortalListingCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([portal])
  @@index([lotId])
  @@index([propertyId])
  @@index([publicationStatus])
  @@index([createdById])
