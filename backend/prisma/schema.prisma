generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENTE
  CORRETOR
  ADMIN
}

enum PropertyType {
  CASA
  APARTAMENTO
  TERRENO
  COMERCIAL
  RURAL
}

enum PropertyStatus {
  DISPONIVEL
  VENDIDO
  RESERVADO
  INDISPONIVEL
}

enum LeadStatus {
  NOVO
  EM_CONTATO
  VISITA
  CONVERTIDO
  PERDIDO
}

enum VisitStatus {
  AGENDADA
  REALIZADA
  CANCELADA
  REMARCADA
}

enum PaymentStatus {
  PENDENTE
  PAGO
  ATRASADO
  CANCELADO
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  phone         String?
  avatar        String?
  role          UserRole  @default(CLIENTE)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  properties    Property[]
  visits        Visit[]
  favorites     Favorite[]
  leads         Lead[]
  clients       Client[]  @relation("BrokerClients")
  payments      Payment[]
  activityLogs  ActivityLog[]
  refreshTokens RefreshToken[]
}

model Property {
  id              String          @id @default(cuid())
  title           String
  description     String?
  type            PropertyType
  status          PropertyStatus  @default(DISPONIVEL)
  price           Decimal         @db.Decimal(12, 2)
  area            Decimal?        @db.Decimal(10, 2)
  bedrooms        Int?
  bathrooms       Int?
  garageSpaces    Int?
  city            String
  neighborhood    String
  street          String?
  number          String?
  complement      String?
  zipCode         String?
  latitude        Decimal?        @db.Decimal(10, 7)
  longitude       Decimal?        @db.Decimal(10, 7)
  userId          String
  developmentId   String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  development     Development?    @relation(fields: [developmentId], references: [id], onDelete: SetNull)
  images          PropertyImage[]
  visits          Visit[]
  favorites       Favorite[]
  leads           Lead[]

  @@index([userId])
  @@index([developmentId])
  @@index([city])
  @@index([status])
  @@index([type])
  @@index([price])
}

model PropertyImage {
  id          String   @id @default(cuid())
  url         String
  publicId    String?
  order       Int      @default(0)
  propertyId  String
  createdAt   DateTime @default(now())

  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model Development {
  id          String   @id @default(cuid())
  name        String
  description String?
  address     String?
  city        String
  neighborhood String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  properties  Property[]
  blocks      Block[]
}

model Block {
  id             String   @id @default(cuid())
  name           String
  developmentId  String
  createdAt      DateTime @default(now())
  updatedAt     DateTime @updatedAt

  development    Development @relation(fields: [developmentId], references: [id], onDelete: Cascade)
  lots           Lot[]

  @@index([developmentId])
}

model Lot {
  id          String   @id @default(cuid())
  blockId     String
  number      String
  area        Decimal? @db.Decimal(10, 2)
  price       Decimal? @db.Decimal(12, 2)
  status      PropertyStatus @default(DISPONIVEL)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  block       Block    @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@index([blockId])
}

model Visit {
  id          String      @id @default(cuid())
  propertyId  String
  userId      String
  clientId    String?
  leadId      String?
  scheduledAt DateTime
  status      VisitStatus  @default(AGENDADA)
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  property    Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  client      Client?     @relation(fields: [clientId], references: [id], onDelete: SetNull)
  lead        Lead?       @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([propertyId])
  @@index([userId])
  @@index([clientId])
  @@index([leadId])
  @@index([scheduledAt])
}

model Client {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  brokerId  String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  broker    User     @relation("BrokerClients", fields: [brokerId], references: [id], onDelete: Cascade)
  visits    Visit[]
  leads     Lead[]

  @@index([brokerId])
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
}

model Lead {
  id          String     @id @default(cuid())
  propertyId  String
  userId      String?
  clientId    String?
  name        String
  email       String
  phone       String?
  message     String?
  source      String?
  status      LeadStatus @default(NOVO)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @default(now()) @updatedAt

  property    Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user        User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  client      Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  visits      Visit[]

  @@index([propertyId])
  @@index([userId])
  @@index([status])
}

model Payment {
  id          String        @id @default(cuid())
  userId      String
  description String
  totalAmount Decimal       @db.Decimal(12, 2)
  status      PaymentStatus @default(PENDENTE)
  dueDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  installments Installment[]

  @@index([userId])
}

model Installment {
  id          String        @id @default(cuid())
  paymentId   String
  amount      Decimal       @db.Decimal(12, 2)
  dueDate     DateTime
  paidAt      DateTime?
  status      PaymentStatus @default(PENDENTE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  payment     Payment       @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  action      String
  entity      String
  entityId    String?
  metadata    Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entity, entityId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
}
