generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENTE
  CORRETOR
  ADMIN
}

enum PropertyType {
  CASA
  APARTAMENTO
  TERRENO
  COMERCIAL
  RURAL
}

enum PropertyStatus {
  DISPONIVEL
  VENDIDO
  RESERVADO
  INDISPONIVEL
}

enum LeadStatus {
  PROSPECCAO
  QUALIFICACAO
  NEGOCIACAO
  VENDIDO
  PERDIDO
}

enum VisitStatus {
  AGENDADA
  REALIZADA
  CANCELADA
  REMARCADA
}

enum AiSuggestionMessageType {
  PRIMEIRO_CONTATO
  FOLLOW_UP
  VISITA
  OPORTUNIDADE
  RETOMADA
  URGENCIA
  POS_VISITA
  NEGOCIACAO
  REATIVACAO_ENCALHADO
}

enum AiSuggestionTone {
  OBJETIVO
  CONSULTIVO
  PERSUASIVO
}

enum PaymentStatus {
  PENDENTE
  PAGO
  ATRASADO
  CANCELADO
}

enum ProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ContractStatus {
  DRAFT
  READY
  SIGNED
  CANCELLED
}

enum SaleStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum LotGeoStatus {
  SEM_LOCALIZACAO
  APROXIMADO
  EXATO
}

enum DevelopmentLocationPrecision {
  EXATA
  APROXIMADA
  PENDENTE
}

enum InstagramContentType {
  FEED
  STORY
  REEL
  CARROSSEL
  ANUNCIO_PATROCINADO
  WHATSAPP_BRIDGE
}

enum InstagramAdTone {
  PROFISSIONAL
  CONSULTIVO
  PERSUASIVO
  PREMIUM
  POPULAR
  URGENTE_SUAVE
  AUTO
}

enum InstagramAdObjective {
  CAPTAR_LEADS
  WHATSAPP
  DESTACAR_CAMPEAO
  REATIVAR_ENCALHADO
  LANCAMENTO
  OPORTUNIDADE
  CONDICAO_ESPECIAL
  LOCALIZACAO
  VISITA
  AUTO
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  phone         String?
  avatar        String?
  role          UserRole  @default(CLIENTE)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  properties    Property[]
  visits        Visit[]
  favorites     Favorite[]
  leads         Lead[]
  clients       Client[]  @relation("BrokerClients")
  payments      Payment[]
  activityLogs  ActivityLog[]
  refreshTokens RefreshToken[]
  simulations   Simulation[]
  proposals     Proposal[]
  contracts     Contract[]
  sales         Sale[]
  leadInteractions LeadInteraction[]
  aiMessageSuggestions AiMessageSuggestion[]
  instagramAdSuggestions InstagramAdSuggestion[]
}

model Property {
  id              String          @id @default(cuid())
  title           String
  description     String?
  type            PropertyType
  status          PropertyStatus  @default(DISPONIVEL)
  price           Decimal         @db.Decimal(12, 2)
  area            Decimal?        @db.Decimal(10, 2)
  bedrooms        Int?
  bathrooms       Int?
  garageSpaces    Int?
  city            String
  neighborhood    String
  street          String?
  number          String?
  complement      String?
  zipCode         String?
  latitude        Decimal?        @db.Decimal(10, 7)
  longitude       Decimal?        @db.Decimal(10, 7)
  userId          String
  developmentId   String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  development     Development?    @relation(fields: [developmentId], references: [id], onDelete: SetNull)
  images          PropertyImage[]
  visits          Visit[]
  favorites       Favorite[]
  leads           Lead[]
  simulations     Simulation[]
  proposals       Proposal[]
  contracts       Contract[]
  sales           Sale[]

  @@index([userId])
  @@index([developmentId])
  @@index([city])
  @@index([status])
  @@index([type])
  @@index([price])
}

model PropertyImage {
  id          String   @id @default(cuid())
  url         String
  publicId    String?
  order       Int      @default(0)
  propertyId  String
  createdAt   DateTime @default(now())

  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model Development {
  id            String   @id @default(cuid())
  name          String
  slug          String?  @unique
  description   String?
  address       String?
  city          String
  state         String?
  neighborhood  String?
  zipCode       String?
  /// Endereço de referência (exibição / geocodificação futura, ex. Nominatim).
  referenceAddress String? @map("reference_address") @db.Text
  locationPrecision DevelopmentLocationPrecision @default(PENDENTE) @map("location_precision")
  locationNotes String? @map("location_notes") @db.Text
  latitude      Decimal? @db.Decimal(10, 7)
  longitude     Decimal? @db.Decimal(10, 7)
  placeId       String?
  polygonCoordinates Json?
  // URL absoluta (Cloudinary/CDN) ou caminho relativo, ex.: /uploads/loteamentos/foto.jpg
  coverImage    String?
  coverImageAlt String?
  coverPublicId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  properties  Property[]
  blocks      Block[]
  instagramAdSuggestions InstagramAdSuggestion[]

  @@index([city])
  @@index([name])
}

model Block {
  id             String   @id @default(cuid())
  name           String
  developmentId  String
  createdAt      DateTime @default(now())
  updatedAt     DateTime @updatedAt

  development    Development @relation(fields: [developmentId], references: [id], onDelete: Cascade)
  lots           Lot[]

  @@index([developmentId])
}

model Lot {
  id                     String         @id @default(cuid())
  blockId                String
  number                 String
  area                   Decimal?       @db.Decimal(10, 2)
  price                  Decimal?       @db.Decimal(12, 2)
  status                 PropertyStatus @default(DISPONIVEL)
  viewCount              Int            @default(0)
  contactCount           Int            @default(0)
  scheduledVisitsCount   Int            @default(0)
  proposalsCount         Int            @default(0)
  availableSince         DateTime?
  manualHighlight        Boolean        @default(false)
  saleScore              Decimal?       @db.Decimal(5, 2)
  saleClassification     String?
  saleScoreReason        String?        @db.Text
  scoredAt               DateTime?
  latitude               Decimal?       @db.Decimal(10, 7)
  longitude              Decimal?       @db.Decimal(10, 7)
  polygonCoordinates     Json?
  mapLabel               String?
  referencePoint         String?
  streetFront            String?
  geoStatus              LotGeoStatus   @default(SEM_LOCALIZACAO)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  block       Block    @relation(fields: [blockId], references: [id], onDelete: Cascade)
  leads       Lead[]
  visits      Visit[]
  aiMessageSuggestions AiMessageSuggestion[]
  instagramAdSuggestions InstagramAdSuggestion[]
  simulations            Simulation[]

  @@index([blockId])
  @@index([status])
  @@index([saleScore])
  @@index([geoStatus])
}

model AiMessageSuggestion {
  id            String                 @id @default(cuid())
  userId        String
  leadId        String?
  lotId         String?
  messageType   AiSuggestionMessageType
  tone          AiSuggestionTone
  message       String                 @db.Text
  justification String                 @db.Text
  createdAt     DateTime               @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead Lead? @relation(fields: [leadId], references: [id], onDelete: Cascade)
  lot  Lot?  @relation(fields: [lotId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([lotId])
  @@index([userId])
  @@index([createdAt])
}

model InstagramAdSuggestion {
  id              String                 @id @default(cuid())
  userId          String
  lotId           String?
  developmentId   String?
  contentType     InstagramContentType
  objective       InstagramAdObjective
  toneRequested   InstagramAdTone?
  strategicNote   String                 @db.Text
  payloadJson     Json
  createdAt       DateTime               @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lot         Lot?         @relation(fields: [lotId], references: [id], onDelete: SetNull)
  development Development? @relation(fields: [developmentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([lotId])
  @@index([developmentId])
  @@index([createdAt])
}

model Visit {
  id          String      @id @default(cuid())
  propertyId  String?
  lotId       String?
  userId      String
  clientId    String?
  leadId      String?
  scheduledAt DateTime
  status      VisitStatus  @default(AGENDADA)
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  property    Property?   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  lot         Lot?        @relation(fields: [lotId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  client      Client?     @relation(fields: [clientId], references: [id], onDelete: SetNull)
  lead        Lead?       @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([propertyId])
  @@index([lotId])
  @@index([userId])
  @@index([clientId])
  @@index([leadId])
  @@index([scheduledAt])
}

model Client {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  brokerId  String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  broker    User     @relation("BrokerClients", fields: [brokerId], references: [id], onDelete: Cascade)
  visits    Visit[]
  leads     Lead[]
  simulations Simulation[]
  proposals   Proposal[]
  contracts   Contract[]
  sales       Sale[]

  @@index([brokerId])
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
}

model Lead {
  id               String     @id @default(cuid())
  propertyId       String?
  lotId            String?
  userId           String?
  clientId         String?
  name             String
  email            String
  phone            String?
  message          String?
  notes            String?
  source           String?
  leadSource       String?
  status           LeadStatus @default(PROSPECCAO)
  isHot            Boolean    @default(false)
  interactionCount Int        @default(0)
  leadLastInteractionAt DateTime?
  closingScore            Decimal?  @db.Decimal(5, 2)
  closingPrediction       String?
  closingReason           String?   @db.Text
  closingInterestLevel    String?
  closingPriorityLevel    String?
  closingNextAction       String?   @db.Text
  closingPositiveFactors  Json?
  closingRiskFactors      Json?
  closingScoreUpdatedAt   DateTime?
  previousClosingScore    Decimal?  @db.Decimal(5, 2)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @default(now()) @updatedAt

  property     Property?          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  lot          Lot?               @relation(fields: [lotId], references: [id], onDelete: SetNull)
  user         User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  client       Client?            @relation(fields: [clientId], references: [id], onDelete: SetNull)
  visits       Visit[]
  interactions LeadInteraction[]
  aiMessageSuggestions AiMessageSuggestion[]
  predictionSnapshots LeadPredictionSnapshot[]

  @@index([propertyId])
  @@index([lotId])
  @@index([userId])
  @@index([status])
  @@index([closingScore])
}

model LeadPredictionSnapshot {
  id                    String   @id @default(cuid())
  leadId                String
  closingScore          Decimal  @db.Decimal(5, 2)
  closingPrediction     String
  closingReason         String   @db.Text
  nextRecommendedAction String   @db.Text
  factorsJson           Json
  previousScore         Decimal? @db.Decimal(5, 2)
  createdAt             DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([createdAt])
}

model LeadInteraction {
  id        String   @id @default(cuid())
  leadId    String
  userId    String?
  type      String
  body      String?
  createdAt DateTime @default(now())

  lead Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([userId])
}

model Payment {
  id          String        @id @default(cuid())
  userId      String
  description String
  totalAmount Decimal       @db.Decimal(12, 2)
  status      PaymentStatus @default(PENDENTE)
  dueDate     DateTime?
  saleId      String?       @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  installments Installment[]
  sale         Sale?         @relation(fields: [saleId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model Installment {
  id          String        @id @default(cuid())
  paymentId   String
  amount      Decimal       @db.Decimal(12, 2)
  dueDate     DateTime
  paidAt      DateTime?
  status      PaymentStatus @default(PENDENTE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  payment     Payment       @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  action      String
  entity      String
  entityId    String?
  metadata    Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entity, entityId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
}

model Bank {
  id          String   @id @default(cuid())
  name        String
  monthlyRate Decimal  @db.Decimal(10, 8)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
}

model Simulation {
  id             String   @id @default(cuid())
  userId         String
  clientName     String
  cpf            String
  clientPhone    String?
  income         Decimal  @db.Decimal(12, 2)
  propertyValue  Decimal  @db.Decimal(14, 2)
  downPayment    Decimal  @db.Decimal(14, 2)
  financedAmount Decimal  @db.Decimal(14, 2)
  age            Int?
  maritalStatus  String?
  dependents     Int      @default(0)
  hasFGTS        Boolean  @default(false)
  fgtsAmount     Decimal  @default(0) @db.Decimal(14, 2)
  clientId       String?
  propertyId     String?
  lotId          String?
  metadata       Json?
  createdAt      DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  client   Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  lot      Lot?      @relation(fields: [lotId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@index([lotId])
}

model Contract {
  id               String         @id @default(cuid())
  proposalId       String         @unique
  userId           String
  clientId         String?
  propertyId       String?
  totalValue       Decimal        @db.Decimal(14, 2)
  downPayment      Decimal        @db.Decimal(14, 2)
  financedAmount   Decimal        @db.Decimal(14, 2)
  bankName         String
  installmentValue Decimal        @db.Decimal(12, 2)
  months           Int
  contractText     String         @db.Text
  clientCpf        String?
  status           ContractStatus @default(DRAFT)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  client   Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  sale     Sale?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Sale {
  id               String     @id @default(cuid())
  contractId       String     @unique
  proposalId       String     @unique
  userId           String
  clientId         String?
  propertyId       String?
  totalValue       Decimal    @db.Decimal(14, 2)
  downPayment      Decimal    @db.Decimal(14, 2)
  financedAmount   Decimal    @db.Decimal(14, 2)
  bankName         String
  installmentValue Decimal    @db.Decimal(12, 2)
  months           Int
  status           SaleStatus @default(CONFIRMED)
  soldAt           DateTime   @default(now())
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  contract Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  proposal Proposal  @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  client   Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  payment  Payment?

  @@index([userId])
  @@index([soldAt])
}

model Proposal {
  id          String         @id @default(cuid())
  userId      String
  clientId    String?
  propertyId  String?
  bank        String
  installment Decimal        @db.Decimal(12, 2)
  months      Int
  downPayment Decimal        @db.Decimal(14, 2)
  status      ProposalStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  client   Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  contract Contract?
  sale     Sale?

  @@index([userId])
  @@index([clientId])
  @@index([propertyId])
  @@index([status])
  @@index([createdAt])
}
