generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENTE
  CORRETOR
  ADMIN
  /// Conta B2B da incorporadora/gestora do loteamento (escopo restrito).
  GESTORA
}

/// Submissão da gestora aguardando revisão administrativa (não entra em “Disponíveis hoje” até aprovação).
enum GestoraSubmissionStatus {
  PENDING_APPROVAL
  REJECTED
}

/// Como publicar atualizações feitas pela gestora (por vínculo usuário ↔ loteamento).
enum GestoraPublishMode {
  IMMEDIATE
  PENDING_REVIEW
}

enum PropertyType {
  CASA
  APARTAMENTO
  TERRENO
  COMERCIAL
  RURAL
}

enum PropertyStatus {
  DISPONIVEL
  VENDIDO
  RESERVADO
  /// Em negociação comercial (pipeline de loteamento)
  EM_NEGOCIACAO
  INDISPONIVEL
}

/// Pipeline comercial CRM (loteamentos): ordem sugerida no funil.
enum LeadStatus {
  NOVO_LEAD
  EM_ATENDIMENTO
  VISITA_AGENDADA
  PROPOSTA_ENVIADA
  RESERVADO
  VENDIDO
  PERDIDO
}

enum VisitStatus {
  AGENDADA
  REALIZADA
  CANCELADA
  REMARCADA
}

enum AiSuggestionMessageType {
  PRIMEIRO_CONTATO
  FOLLOW_UP
  VISITA
  OPORTUNIDADE
  RETOMADA
  URGENCIA
  POS_VISITA
  NEGOCIACAO
  REATIVACAO_ENCALHADO
}

enum AiSuggestionTone {
  OBJETIVO
  CONSULTIVO
  PERSUASIVO
}

enum PaymentStatus {
  PENDENTE
  PAGO
  ATRASADO
  CANCELADO
}

enum ProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ContractStatus {
  DRAFT
  READY
  SIGNED
  CANCELLED
}

enum SaleStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum LotGeoStatus {
  SEM_LOCALIZACAO
  APROXIMADO
  EXATO
}

enum DevelopmentLocationPrecision {
  EXATA
  APROXIMADA
  PENDENTE
}

enum DevelopmentGeocodingStatus {
  VERIFIED
  APPROXIMATE
  PENDING
}

enum InstagramContentType {
  FEED
  STORY
  REEL
  CARROSSEL
  ANUNCIO_PATROCINADO
  WHATSAPP_BRIDGE
}

enum InstagramAdTone {
  PROFISSIONAL
  CONSULTIVO
  PERSUASIVO
  PREMIUM
  POPULAR
  URGENTE_SUAVE
  AUTO
}

enum InstagramAdObjective {
  CAPTAR_LEADS
  WHATSAPP
  DESTACAR_CAMPEAO
  REATIVAR_ENCALHADO
  LANCAMENTO
  OPORTUNIDADE
  CONDICAO_ESPECIAL
  LOCALIZACAO
  VISITA
  AUTO
}

enum MarketingCampaignStatus {
  DRAFT
  READY
  SCHEDULED
  QUEUED
  PROCESSING
  PUBLISHED
  FAILED
  RETRYING
  CANCELED
  ARCHIVED
}

/// Tipo comercial da campanha (camada de produto; independente do motor de anúncios Instagram).
enum MarketingCampaignKind {
  LOTEMENTO
  LOTE
  INSTITUCIONAL
  PROMOCAO
  REENGAJAMENTO
}

/// Objetivo comercial declarado (planejamento / relatórios).
enum CommercialObjective {
  GERAR_LEADS
  GERAR_VISITAS
  DIVULGAR_LOTES
  FORTALECER_MARCA
}

enum CampaignAssetKind {
  IMAGE
  VIDEO
  GENERATED_IMAGE
  UPLOADED_IMAGE
  SYSTEM_IMAGE
}

enum CampaignAssetOrigin {
  BANK
  UPLOAD
  AI
}

enum PublicationPlatform {
  INSTAGRAM_FEED
  INSTAGRAM_STORY
  INSTAGRAM_REEL
  FACEBOOK_POST
  WHATSAPP
  EXPORT_PACKAGE
}

enum PublicationTargetStatus {
  PREPARED
  EXPORT_PENDING
  PUBLISHED
  FAILED
}

enum AiImageJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum SocialProvider {
  META_PAGE
}

enum SocialConnectionStatus {
  ACTIVE
  EXPIRED
  REVOKED
  ERROR
  /// OAuth só com escopo mínimo (ex.: public_profile); página/Instagram não disponível até etapa estendida.
  META_BASIC_CONNECTED
}

/// Origem do registro da central de disponibilidade diária (não altera o status cadastral do lote).
enum DailyAvailabilitySourceType {
  IMAGE
  CSV
  /// Planilha estruturada (xlsx/csv) importada pela gestora.
  SPREADSHEET
  TEXT
  MANUAL
}

/// Estado comercial do dia (snapshot operacional; independente de PropertyStatus no cadastro).
enum LotDailySnapshotStatus {
  DISPONIVEL
  RESERVADO
  VENDIDO
  NEGOCIACAO
}

// --- CRM inteligente: áudio, match, portais ---

enum AudioIngestionStatus {
  UPLOADED
  TRANSCRIBING
  TRANSCRIBED
  EXTRACTED
  FAILED
  APPLIED
}

enum PropertyIntent {
  MORAR
  INVESTIR
  OUTRO
}

enum MatchTargetKind {
  LOT
  PROPERTY
}

enum MatchSuggestionStatus {
  SUGGESTED
  DISMISSED
  SENT_TO_CLIENT
  VISIT_SCHEDULED
  CONVERTED
}

enum CatalogShareStatus {
  DRAFT
  SENT
  ARCHIVED
}

enum PortalCode {
  OLX
  GRUPO_OLX_XML
  ORULO
  HOMER
  DWV
  CUSTOM
}

enum PortalListingLifecycleStatus {
  DRAFT
  READY
  PENDING_SYNC
  PUBLISHED
  FAILED
  REMOVED
  OUT_OF_SYNC
}

enum ExternalLeadIngestStatus {
  RECEIVED
  DEDUPLICATED
  CRM_LEAD_CREATED
  FAILED
}

/// Conversa comercial vinculada a lead, lote ou imóvel (chat interno).
enum ChatConversationType {
  LEAD
  LOT
  PROPERTY
}

enum ChatMessageType {
  TEXT
  SYSTEM
  ACTION
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  phone         String?
  avatar        String?
  role          UserRole  @default(CLIENTE)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  properties    Property[]
  visits        Visit[]
  favorites     Favorite[]
  leads         Lead[]
  clients       Client[]  @relation("BrokerClients")
  payments      Payment[]
  activityLogs  ActivityLog[]
  refreshTokens RefreshToken[]
  simulations   Simulation[]
  proposals     Proposal[]
  contracts     Contract[]
  sales         Sale[]
  leadInteractions LeadInteraction[]
  aiMessageSuggestions AiMessageSuggestion[]
  instagramAdSuggestions InstagramAdSuggestion[]
  marketingCampaigns     MarketingCampaign[]
  socialConnections      SocialConnection[]
  socialIntegrationLogs  SocialIntegrationLog[]
  campaignPublicationOpLogs CampaignPublicationOpLog[]
  dailyAvailabilitiesCreated DailyAvailability[] @relation("DailyAvailabilityCreatedBy")
  lotImageMapsCreated        LotImageMap[]       @relation("LotImageMapCreatedBy")
  spreadsheetImportTemplatesCreated SpreadsheetImportTemplate[] @relation("SpreadsheetImportTemplateCreatedBy")
  audioIngestions              AudioIngestion[]
  portalListingsCreated        PortalListing[] @relation("PortalListingCreatedBy")
  catalogShares                CatalogShare[]
  inAppNotifications           InAppNotification[]
  portalConnectorConfigs       PortalConnectorConfig[]
  managerDevelopmentAccess     ManagerDevelopmentAccess[]
  conversationsAsBroker        Conversation[]             @relation("ChatConversationBroker")
  conversationsAsClient        Conversation[]             @relation("ChatConversationClient")
  conversationParticipants     ConversationParticipant[]
  chatMessagesSent             ChatMessage[]
}

model Property {
  id              String          @id @default(cuid())
  title           String
  description     String?
  type            PropertyType
  status          PropertyStatus  @default(DISPONIVEL)
  price           Decimal         @db.Decimal(12, 2)
  area            Decimal?        @db.Decimal(10, 2)
  bedrooms        Int?
  bathrooms       Int?
  garageSpaces    Int?
  city            String
  neighborhood    String
  street          String?
  number          String?
  complement      String?
  zipCode         String?
  latitude        Decimal?        @db.Decimal(10, 7)
  longitude       Decimal?        @db.Decimal(10, 7)
  userId          String
  developmentId   String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  development     Development?    @relation(fields: [developmentId], references: [id], onDelete: SetNull)
  images          PropertyImage[]
  visits          Visit[]
  favorites       Favorite[]
  leads           Lead[]
  simulations     Simulation[]
  proposals       Proposal[]
  contracts       Contract[]
  sales           Sale[]
  portalListings  PortalListing[]
  matchSuggestions MatchSuggestion[]
  chatConversations Conversation[]

  @@index([userId])
  @@index([developmentId])
  @@index([city])
  @@index([status])
  @@index([type])
  @@index([price])
}

model PropertyImage {
  id          String   @id @default(cuid())
  url         String
  publicId    String?
  order       Int      @default(0)
  propertyId  String
  createdAt   DateTime @default(now())

  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  /// Referências em campanhas (não remove a imagem da galeria do imóvel).
  campaignAssetRefs CampaignAsset[] @relation("CampaignAssetSourceImage")

  @@index([propertyId])
}

model Development {
  id            String   @id @default(cuid())
  name          String
  slug          String?  @unique
  description   String?
  address       String?
  /// Logradouro (rua) estruturado, quando separado de `address`.
  street        String?
  streetNumber  String?  @map("street_number")
  city          String
  state         String?
  neighborhood  String?
  zipCode       String?
  /// Endereço de referência (exibição / geocodificação futura, ex. Nominatim).
  referenceAddress String? @map("reference_address") @db.Text
  locationPrecision DevelopmentLocationPrecision @default(PENDENTE) @map("location_precision")
  locationNotes String? @map("location_notes") @db.Text
  placeName     String?  @map("place_name")
  geocodingStatus DevelopmentGeocodingStatus @default(PENDING) @map("geocoding_status")
  geocodingConfidence Decimal? @map("geocoding_confidence") @db.Decimal(6, 4)
  polygonSource String?  @map("polygon_source")
  locationVerifiedAt DateTime? @map("location_verified_at")
  latitude      Decimal? @db.Decimal(10, 7)
  longitude     Decimal? @db.Decimal(10, 7)
  placeId       String?
  polygonCoordinates Json?
  // URL absoluta (Cloudinary/CDN) ou caminho relativo, ex.: /uploads/loteamentos/foto.jpg
  coverImage    String?
  coverImageAlt String?
  coverPublicId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  properties  Property[]
  blocks      Block[]
  leads       Lead[]
  instagramAdSuggestions InstagramAdSuggestion[]
  marketingCampaigns     MarketingCampaign[]
  nearbyPlaces DevelopmentNearbyPlace[]
  dailyAvailabilities DailyAvailability[]
  lotImageMaps      LotImageMap[]
  spreadsheetImportTemplates SpreadsheetImportTemplate[]
  managerDevelopmentAccess   ManagerDevelopmentAccess[]

  @@index([city])
  @@index([name])
  @@index([geocodingStatus])
}

/// Vínculo gestora ↔ loteamentos autorizados (escopo B2B).
model ManagerDevelopmentAccess {
  id                         String             @id @default(cuid())
  userId                     String             @map("user_id")
  developmentId              String             @map("development_id")
  /// JSON livre para evolução (flags adicionais).
  permissions                Json?              @map("permissions")
  spreadsheetImportEnabled   Boolean            @default(true) @map("spreadsheet_import_enabled")
  assistedImageEnabled       Boolean            @default(true) @map("assisted_image_enabled")
  publishMode                GestoraPublishMode @default(IMMEDIATE) @map("publish_mode")
  createdAt                  DateTime           @default(now()) @map("created_at")
  updatedAt                  DateTime           @updatedAt @map("updated_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  development Development @relation(fields: [developmentId], references: [id], onDelete: Cascade)

  @@unique([userId, developmentId])
  @@index([userId])
  @@index([developmentId])
}

/// POIs próximos ao loteamento (cache; fonte típica Overpass/OSM).
model DevelopmentNearbyPlace {
  id                   String   @id @default(cuid())
  developmentId        String   @map("development_id")
  name                 String
  category             String
  subcategory          String?
  latitude             Decimal  @db.Decimal(10, 7)
  longitude            Decimal  @db.Decimal(10, 7)
  shortAddress         String?  @map("short_address")
  source               String   @default("overpass")
  sourceOsmId          String?  @map("source_osm_id")
  searchRadiusMeters   Int      @default(3000) @map("search_radius_meters")
  distanceMeters       Int?     @map("distance_meters")
  travelTimeMinutes    Int?     @map("travel_time_minutes")
  travelMode           String   @default("driving") @map("travel_mode")
  routeSource          String?  @map("route_source")
  fetchedAt            DateTime @default(now()) @map("fetched_at")
  updatedAt            DateTime @updatedAt

  development Development @relation(fields: [developmentId], references: [id], onDelete: Cascade)

  @@index([developmentId])
  @@index([category])
  @@unique([developmentId, source, sourceOsmId, travelMode, searchRadiusMeters])
}

model Block {
  id             String   @id @default(cuid())
  name           String
  developmentId  String
  createdAt      DateTime @default(now())
  updatedAt     DateTime @updatedAt

  development    Development @relation(fields: [developmentId], references: [id], onDelete: Cascade)
  lots           Lot[]
  marketingCampaigns MarketingCampaign[]

  @@index([developmentId])
}

model Lot {
  id                     String         @id @default(cuid())
  blockId                String
  number                 String
  area                   Decimal?       @db.Decimal(10, 2)
  price                  Decimal?       @db.Decimal(12, 2)
  status                 PropertyStatus @default(DISPONIVEL)
  viewCount              Int            @default(0)
  contactCount           Int            @default(0)
  scheduledVisitsCount   Int            @default(0)
  proposalsCount         Int            @default(0)
  availableSince         DateTime?
  manualHighlight        Boolean        @default(false)
  saleScore              Decimal?       @db.Decimal(5, 2)
  saleClassification     String?
  saleScoreReason        String?        @db.Text
  scoredAt               DateTime?
  latitude               Decimal?       @db.Decimal(10, 7)
  longitude              Decimal?       @db.Decimal(10, 7)
  polygonCoordinates     Json?
  mapLabel               String?
  referencePoint         String?
  streetFront            String?
  geoStatus              LotGeoStatus   @default(SEM_LOCALIZACAO)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  block       Block    @relation(fields: [blockId], references: [id], onDelete: Cascade)
  leads       Lead[]
  visits      Visit[]
  aiMessageSuggestions AiMessageSuggestion[]
  instagramAdSuggestions InstagramAdSuggestion[]
  marketingCampaigns     MarketingCampaign[]
  simulations            Simulation[]
  dailySnapshots         LotDailyStatus[]
  portalListings         PortalListing[]
  matchSuggestions       MatchSuggestion[]
  lotImageMap            LotImageMap?
  chatConversations      Conversation[]

  @@index([blockId])
  @@index([status])
  @@index([saleScore])
  @@index([geoStatus])
}

/// Atualização diária de disponibilidade por loteamento (histórico: vários registros por dia permitidos).
model DailyAvailability {
  id                String   @id @default(cuid())
  developmentId     String
  date              DateTime @db.Date
  sourceType        DailyAvailabilitySourceType
  sourceFileUrl     String?
  notes             String?  @db.Text
  rawText           String?  @db.Text
  /// Metadados do fluxo assistido (imagem, confirmação, resumo) — opcional.
  assistedMetadata  Json?    @map("assisted_metadata")
  /// Metadados de importação por planilha (arquivo, linhas, template, erros) — opcional.
  importMetadata    Json?    @map("import_metadata")
  /// Null = publicado / fluxo admin; PENDING = aguardando aprovação; REJECTED = recusado pelo admin.
  gestoraSubmissionStatus GestoraSubmissionStatus? @map("gestora_submission_status")
  createdById       String
  createdAt         DateTime @default(now())

  development       Development @relation(fields: [developmentId], references: [id], onDelete: Cascade)
  createdBy         User        @relation("DailyAvailabilityCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  lotSnapshots      LotDailyStatus[]

  @@index([developmentId, date])
  @@index([developmentId, date, createdAt])
  @@index([developmentId, date, gestoraSubmissionStatus])
  @@index([createdById])
}

/// Template visual: posição do lote na planta/imagem (coordenadas normalizadas 0–1 para reutilizar entre fotos).
model LotImageMap {
  id              String   @id @default(cuid())
  developmentId   String
  lotId           String   @unique
  xNorm           Decimal  @db.Decimal(8, 7)
  yNorm           Decimal  @db.Decimal(8, 7)
  wNorm           Decimal? @db.Decimal(8, 7)
  hNorm           Decimal? @db.Decimal(8, 7)
  refImageWidth   Int?
  refImageHeight  Int?
  createdById     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  development Development @relation(fields: [developmentId], references: [id], onDelete: Cascade)
  lot         Lot         @relation(fields: [lotId], references: [id], onDelete: Cascade)
  createdBy   User        @relation("LotImageMapCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([developmentId])
}

/// Template de colunas da planilha da gestora (reutilização por loteamento).
model SpreadsheetImportTemplate {
  id               String   @id @default(cuid())
  name             String
  /// Rótulo da gestora (ex.: nome da incorporadora).
  gestoraLabel     String?  @map("gestora_label")
  developmentId    String   @map("development_id")
  /// Mapeamento: quadra, lote, status, preço, area, observacao, loteamento (opcional).
  columnMapping    Json     @map("column_mapping")
  createdById      String   @map("created_by_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  development Development @relation(fields: [developmentId], references: [id], onDelete: Cascade)
  createdBy   User        @relation("SpreadsheetImportTemplateCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([developmentId])
}

/// Snapshot do estado comercial do lote naquela atualização diária.
model LotDailyStatus {
  id                  String   @id @default(cuid())
  dailyAvailabilityId String
  lotId               String
  status              LotDailySnapshotStatus
  price               Decimal? @db.Decimal(12, 2)
  notes               String?  @db.Text

  dailyAvailability   DailyAvailability @relation(fields: [dailyAvailabilityId], references: [id], onDelete: Cascade)
  lot                 Lot               @relation(fields: [lotId], references: [id], onDelete: Cascade)

  @@unique([dailyAvailabilityId, lotId])
  @@index([lotId])
}

model AiMessageSuggestion {
  id            String                 @id @default(cuid())
  userId        String
  leadId        String?
  lotId         String?
  messageType   AiSuggestionMessageType
  tone          AiSuggestionTone
  message       String                 @db.Text
  justification String                 @db.Text
  createdAt     DateTime               @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead Lead? @relation(fields: [leadId], references: [id], onDelete: Cascade)
  lot  Lot?  @relation(fields: [lotId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([lotId])
  @@index([userId])
  @@index([createdAt])
}

model InstagramAdSuggestion {
  id              String                 @id @default(cuid())
  userId          String
  lotId           String?
  developmentId   String?
  contentType     InstagramContentType
  objective       InstagramAdObjective
  toneRequested   InstagramAdTone?
  strategicNote   String                 @db.Text
  payloadJson     Json
  createdAt       DateTime               @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lot         Lot?         @relation(fields: [lotId], references: [id], onDelete: SetNull)
  development Development? @relation(fields: [developmentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([lotId])
  @@index([developmentId])
  @@index([createdAt])
}

model MarketingCampaign {
  id                 String                   @id @default(cuid())
  userId             String                   @map("user_id")
  /// Opcional para campanhas institucionais / marca sem empreendimento fixo.
  developmentId      String?                  @map("development_id")
  lotId              String?                  @map("lot_id")
  /// Escopo por quadra (divulgação de faixa de lotes), quando aplicável.
  blockId            String?                  @map("block_id")
  title              String
  /// Motor legado de anúncios Instagram (mantido para compatibilidade com geração existente).
  objective          InstagramAdObjective     @default(AUTO)
  campaignKind       MarketingCampaignKind    @default(LOTEMENTO) @map("campaign_kind")
  commercialObjective CommercialObjective?    @map("commercial_objective")
  /// Descrição interna (time comercial; não é legenda pública).
  internalDescription String?                 @map("internal_description") @db.Text
  /// Público-alvo / persona (planejamento).
  audienceNotes      String?                  @map("audience_notes") @db.Text
  /// Legenda principal unificada (espelhada nas cópias ao aplicar templates).
  primaryCaption     String?                  @map("primary_caption") @db.Text
  status             MarketingCampaignStatus  @default(DRAFT)
  primaryContentType InstagramContentType     @default(FEED) @map("primary_content_type")
  packJson           Json?                    @map("pack_json")
  lastGeneratedAt    DateTime?                @map("last_generated_at")
  /// Agendamento desejado (publicação futura; integração Meta usará alvos/cópias).
  scheduledPublishAt DateTime?                @map("scheduled_publish_at")
  /// IANA timezone (ex.: America/Sao_Paulo) para exibição e regras de agenda.
  scheduleTimezone   String?                  @default("America/Sao_Paulo") @map("schedule_timezone")
  /// Canais a publicar automaticamente (JSON array de PublicationPlatform, ex.: ["INSTAGRAM_FEED","FACEBOOK_POST"]).
  scheduledChannelsJson Json?               @map("scheduled_channels_json")
  /// Conexão Meta opcional para o agendamento (usa padrão do usuário se null).
  scheduledSocialConnectionId String?        @map("scheduled_social_connection_id")
  autoRetryEnabled   Boolean                  @default(true) @map("auto_retry_enabled")
  retryCount         Int                      @default(0) @map("retry_count")
  maxRetries         Int                      @default(3) @map("max_retries")
  lastPublishAttemptAt DateTime?             @map("last_publish_attempt_at")
  nextRetryAt        DateTime?                @map("next_retry_at")
  campaignPublishedAt DateTime?             @map("campaign_published_at")
  publishFailureReason String?               @map("publish_failure_reason") @db.Text
  /// Evita processamento paralelo do mesmo job (worker).
  publicationLockUntil DateTime?             @map("publication_lock_until")
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")

  user         User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  development  Development?                @relation(fields: [developmentId], references: [id], onDelete: Cascade)
  lot          Lot?                        @relation(fields: [lotId], references: [id], onDelete: SetNull)
  block        Block?                      @relation(fields: [blockId], references: [id], onDelete: SetNull)
  assets       CampaignAsset[]
  targets      CampaignPublicationTarget[]
  copies       CampaignCopy[]
  aiImageJobs  AiImageGenerationJob[]
  publicationOpLogs CampaignPublicationOpLog[]
  leads             Lead[]

  @@index([userId])
  @@index([developmentId])
  @@index([lotId])
  @@index([blockId])
  @@index([status])
  @@index([campaignKind])
  @@index([createdAt])
  @@index([scheduledPublishAt])
  @@index([nextRetryAt])
  @@index([status, scheduledPublishAt])
  @@map("marketing_campaigns")
}

/// Histórico operacional de agendamento e publicação (sem segredos).
model CampaignPublicationOpLog {
  id               String   @id @default(cuid())
  campaignId       String   @map("campaign_id")
  /// Dono da campanha (contexto); pode ser null em jobs legados.
  userId           String?  @map("user_id")
  action           String
  channel          String?
  status           String
  message          String?  @db.Text
  externalPostId   String?  @map("external_post_id")
  attemptNumber    Int      @default(0) @map("attempt_number")
  executedByUserId String?  @map("executed_by_user_id")
  metadataJson     Json?    @map("metadata_json")
  createdAt        DateTime @default(now()) @map("created_at")

