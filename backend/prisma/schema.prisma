  metadataJson        Json?
  createdById         String
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  createdBy User @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@unique([portal, label])
