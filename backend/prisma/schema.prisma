model Contract {
  id               String         @id @default(cuid())
  proposalId       String         @unique
  userId           String
  clientId         String?
  propertyId       String?
  totalValue       Decimal        @db.Decimal(14, 2)
  downPayment      Decimal        @db.Decimal(14, 2)
  financedAmount   Decimal        @db.Decimal(14, 2)
  bankName         String
  installmentValue Decimal        @db.Decimal(12, 2)
  months           Int
  contractText     String         @db.Text
  clientCpf        String?
  status           ContractStatus @default(DRAFT)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  client   Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  sale     Sale?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Sale {
  id               String     @id @default(cuid())
  contractId       String     @unique
  proposalId       String     @unique
  userId           String
  clientId         String?
  propertyId       String?
  totalValue       Decimal    @db.Decimal(14, 2)
  downPayment      Decimal    @db.Decimal(14, 2)
  financedAmount   Decimal    @db.Decimal(14, 2)
  bankName         String
  installmentValue Decimal    @db.Decimal(12, 2)
  months           Int
  status           SaleStatus @default(CONFIRMED)
  soldAt           DateTime   @default(now())
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  contract Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  proposal Proposal  @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  client   Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  payment  Payment?

  @@index([userId])
  @@index([soldAt])
}

model Proposal {
  id          String         @id @default(cuid())
  userId      String
  clientId    String?
  propertyId  String?
  bank        String
  installment Decimal        @db.Decimal(12, 2)
  months      Int
  downPayment Decimal        @db.Decimal(14, 2)
  status      ProposalStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  client   Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  contract Contract?
  sale     Sale?

  @@index([userId])
  @@index([clientId])
  @@index([propertyId])
  @@index([status])
  @@index([createdAt])
}

/// Perfil comercial / preferências para match (lead ou cliente).
model InterestProfile {
  id                      String          @id @default(cuid())
  leadId                  String?         @unique
  clientId                String?         @unique
  budgetMin               Decimal?        @db.Decimal(18, 2)
  budgetMax               Decimal?        @db.Decimal(18, 2)
  preferredDevelopmentIds String[]        @default([])
  preferredRegions        String[]        @default([])
  minArea                 Decimal?        @db.Decimal(14, 2)
  maxArea                 Decimal?        @db.Decimal(14, 2)
  propertyIntent          PropertyIntent?
  financingNotes          String?         @db.Text
  mustHaveTags            String[]        @default([])
  niceToHaveTags          String[]        @default([])
  urgencyLevel            String?
  extraJson               Json?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

/// Ingestão de áudio + transcrição + extração revisável.
model AudioIngestion {
  id                    String               @id @default(cuid())
  userId                String
  leadId                String?
  clientId              String?
  sourceUrl             String
  publicId              String?
  mimeType              String
  durationMs            Int?
  status                AudioIngestionStatus   @default(UPLOADED)
  transcriptRaw       String?                @db.Text
  transcriptConfidence  Float?
  extractionJson        Json?
  extractionError       String?                @db.Text
  appliedAt             DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([leadId])
  @@index([clientId])
  @@index([status])
}

/// Sugestão de match lead ↔ lote/imóvel.
model MatchSuggestion {
  id           String                 @id @default(cuid())
  leadId       String
  kind         MatchTargetKind
  lotId        String?
  propertyId   String?
