model Favorite {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
}

model Lead {
  id               String     @id @default(cuid())
  propertyId       String?
  lotId            String?
  /// Interesse no loteamento (quando ainda sem lote específico).
  developmentId    String?    @map("development_id")
  userId           String?
  clientId         String?
  name             String
  email            String
  phone            String?
  message          String?
  notes            String?
  source           String?
  leadSource       String?
  status           LeadStatus @default(NOVO_LEAD)
  /// Próximo follow-up comercial (retorno agendado).
  nextFollowUpAt   DateTime?  @map("next_follow_up_at")
  /// Motivo registrado ao marcar como PERDIDO.
  lostReason       String?    @map("lost_reason") @db.Text
  isHot            Boolean    @default(false)
  interactionCount Int        @default(0)
  leadLastInteractionAt DateTime?
  /// Campanha de marketing que originou o lead (atribuição para analytics).
  marketingCampaignId String? @map("marketing_campaign_id")
  closingScore            Decimal?  @db.Decimal(5, 2)
  closingPrediction       String?
  closingReason           String?   @db.Text
  closingInterestLevel    String?
  closingPriorityLevel    String?
  closingNextAction       String?   @db.Text
  closingPositiveFactors  Json?
  closingRiskFactors      Json?
  closingScoreUpdatedAt   DateTime?
  previousClosingScore    Decimal?  @db.Decimal(5, 2)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @default(now()) @updatedAt

  property     Property?          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  lot          Lot?               @relation(fields: [lotId], references: [id], onDelete: SetNull)
  development  Development?     @relation(fields: [developmentId], references: [id], onDelete: SetNull)
  user         User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  client       Client?            @relation(fields: [clientId], references: [id], onDelete: SetNull)
  marketingCampaign MarketingCampaign? @relation(fields: [marketingCampaignId], references: [id], onDelete: SetNull)
  visits       Visit[]
  interactions LeadInteraction[]
  aiMessageSuggestions AiMessageSuggestion[]
  predictionSnapshots LeadPredictionSnapshot[]
  interestProfile      InterestProfile?
  audioIngestions      AudioIngestion[]
  matchSuggestions     MatchSuggestion[]
  catalogShares        CatalogShare[]
  externalPortalLeads  ExternalPortalLead[]
  conversation         Conversation?

  @@index([propertyId])
  @@index([lotId])
  @@index([developmentId])
  @@index([userId])
  @@index([status])
  @@index([closingScore])
  @@index([nextFollowUpAt])
  @@index([marketingCampaignId])
}

model LeadPredictionSnapshot {
