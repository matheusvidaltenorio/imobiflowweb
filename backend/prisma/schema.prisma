  portal            PortalCode
  externalLeadId    String
  listingReference  String?
  rawPayload        Json
  dedupeKey         String                  @unique
  leadId            String?
  status            ExternalLeadIngestStatus  @default(RECEIVED)
  errorMessage      String?                 @db.Text
  createdAt         DateTime                @default(now())
  processedAt       DateTime?

  lead Lead? @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([portal])
  @@index([createdAt])
  @@index([status])
}

model InAppNotification {
  id           String    @id @default(cuid())
  userId       String
  type         String
  title        String
  body         String?   @db.Text
  metadataJson Json?
  readAt       DateTime?
  createdAt    DateTime  @default(now())

  /// Escopo comercial (alertas de disponibilidade / match).
  developmentId       String? @map("development_id")
  lotId               String? @map("lot_id")
  dailyAvailabilityId String? @map("daily_availability_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([createdAt])
  @@index([userId, developmentId])
  @@index([dailyAvailabilityId])
  @@index([userId, type, dailyAvailabilityId, lotId])
}

/// Thread de chat interno (CRM / negociação).
model Conversation {
  id                String               @id @default(cuid())
  type              ChatConversationType
  leadId            String?              @unique
  lotId             String?
  propertyId        String?
  brokerUserId      String               @map("broker_user_id")
  clientUserId      String?              @map("client_user_id")
  whatsappHandoffAt DateTime?            @map("whatsapp_handoff_at")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  lead         Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  lot          Lot?      @relation(fields: [lotId], references: [id], onDelete: SetNull)
  property     Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  brokerUser   User      @relation("ChatConversationBroker", fields: [brokerUserId], references: [id], onDelete: Cascade)
  clientUser   User?     @relation("ChatConversationClient", fields: [clientUserId], references: [id], onDelete: SetNull)
  participants ConversationParticipant[]
  messages     ChatMessage[]

  @@unique([lotId, clientUserId], map: "Conversation_lot_client_uidx")
  @@unique([propertyId, clientUserId], map: "Conversation_property_client_uidx")
  @@index([brokerUserId])
  @@index([clientUserId])
}

model ConversationParticipant {
  conversationId String    @map("conversation_id")
  userId         String    @map("user_id")
  lastReadAt     DateTime? @map("last_read_at")
  joinedAt       DateTime  @default(now()) @map("joined_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId])
}

model ChatMessage {
  id             String          @id @default(cuid())
  conversationId String          @map("conversation_id")
  senderId       String?         @map("sender_id")
  content        String          @db.Text
  type           ChatMessageType @default(TEXT)
  metadata       Json?
  createdAt      DateTime        @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User?        @relation(fields: [senderId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([senderId])
}
