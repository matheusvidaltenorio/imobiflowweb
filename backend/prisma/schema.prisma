generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENTE
  CORRETOR
  ADMIN
}

enum PropertyType {
  CASA
  APARTAMENTO
  TERRENO
  COMERCIAL
  RURAL
}

enum PropertyStatus {
  DISPONIVEL
  VENDIDO
  RESERVADO
  INDISPONIVEL
}

enum LeadStatus {
  PROSPECCAO
  QUALIFICACAO
  NEGOCIACAO
  VENDIDO
  PERDIDO
}

enum VisitStatus {
  AGENDADA
  REALIZADA
  CANCELADA
  REMARCADA
}

enum AiSuggestionMessageType {
  PRIMEIRO_CONTATO
  FOLLOW_UP
  VISITA
  OPORTUNIDADE
  RETOMADA
  URGENCIA
  POS_VISITA
  NEGOCIACAO
  REATIVACAO_ENCALHADO
}

enum AiSuggestionTone {
  OBJETIVO
  CONSULTIVO
  PERSUASIVO
}

enum PaymentStatus {
  PENDENTE
  PAGO
  ATRASADO
  CANCELADO
}

enum ProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ContractStatus {
  DRAFT
  READY
  SIGNED
  CANCELLED
}

enum SaleStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum LotGeoStatus {
  SEM_LOCALIZACAO
  APROXIMADO
  EXATO
}

enum DevelopmentLocationPrecision {
  EXATA
  APROXIMADA
  PENDENTE
}

enum DevelopmentGeocodingStatus {
  VERIFIED
  APPROXIMATE
  PENDING
}

enum InstagramContentType {
  FEED
  STORY
  REEL
  CARROSSEL
  ANUNCIO_PATROCINADO
  WHATSAPP_BRIDGE
}

enum InstagramAdTone {
  PROFISSIONAL
  CONSULTIVO
  PERSUASIVO
  PREMIUM
  POPULAR
  URGENTE_SUAVE
  AUTO
}

enum InstagramAdObjective {
  CAPTAR_LEADS
  WHATSAPP
  DESTACAR_CAMPEAO
  REATIVAR_ENCALHADO
  LANCAMENTO
  OPORTUNIDADE
  CONDICAO_ESPECIAL
  LOCALIZACAO
  VISITA
  AUTO
}

enum MarketingCampaignStatus {
  DRAFT
  READY
  ARCHIVED
}

enum CampaignAssetKind {
  IMAGE
  VIDEO
  GENERATED_IMAGE
  UPLOADED_IMAGE
  SYSTEM_IMAGE
}

enum CampaignAssetOrigin {
  BANK
  UPLOAD
  AI
}

enum PublicationPlatform {
  INSTAGRAM_FEED
  INSTAGRAM_STORY
  INSTAGRAM_REEL
  FACEBOOK_POST
  WHATSAPP
  EXPORT_PACKAGE
}

enum PublicationTargetStatus {
  PREPARED
  EXPORT_PENDING
  PUBLISHED
  FAILED
}

enum AiImageJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum SocialProvider {
  META_PAGE
}

enum SocialConnectionStatus {
  ACTIVE
  EXPIRED
  REVOKED
  ERROR
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  phone         String?
  avatar        String?
  role          UserRole  @default(CLIENTE)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  properties    Property[]
  visits        Visit[]
  favorites     Favorite[]
  leads         Lead[]
  clients       Client[]  @relation("BrokerClients")
  payments      Payment[]
  activityLogs  ActivityLog[]
  refreshTokens RefreshToken[]
  simulations   Simulation[]
  proposals     Proposal[]
  contracts     Contract[]
  sales         Sale[]
  leadInteractions LeadInteraction[]
  aiMessageSuggestions AiMessageSuggestion[]
  instagramAdSuggestions InstagramAdSuggestion[]
  marketingCampaigns     MarketingCampaign[]
  socialConnections      SocialConnection[]
}

model Property {
  id              String          @id @default(cuid())
  title           String
  description     String?
  type            PropertyType
  status          PropertyStatus  @default(DISPONIVEL)
  price           Decimal         @db.Decimal(12, 2)
  area            Decimal?        @db.Decimal(10, 2)
  bedrooms        Int?
  bathrooms       Int?
  garageSpaces    Int?
  city            String
  neighborhood    String
  street          String?
  number          String?
  complement      String?
  zipCode         String?
  latitude        Decimal?        @db.Decimal(10, 7)
  longitude       Decimal?        @db.Decimal(10, 7)
  userId          String
  developmentId   String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  development     Development?    @relation(fields: [developmentId], references: [id], onDelete: SetNull)
  images          PropertyImage[]
  visits          Visit[]
  favorites       Favorite[]
  leads           Lead[]
  simulations     Simulation[]
  proposals       Proposal[]
  contracts       Contract[]
  sales           Sale[]

  @@index([userId])
  @@index([developmentId])
  @@index([city])
  @@index([status])
  @@index([type])
  @@index([price])
}

model PropertyImage {
  id          String   @id @default(cuid())
  url         String
  publicId    String?
  order       Int      @default(0)
  propertyId  String
  createdAt   DateTime @default(now())

  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model Development {
  id            String   @id @default(cuid())
  name          String
  slug          String?  @unique
  description   String?
  address       String?
  /// Logradouro (rua) estruturado, quando separado de `address`.
  street        String?
  streetNumber  String?  @map("street_number")
  city          String
  state         String?
  neighborhood  String?
  zipCode       String?
  /// Endereço de referência (exibição / geocodificação futura, ex. Nominatim).
  referenceAddress String? @map("reference_address") @db.Text
  locationPrecision DevelopmentLocationPrecision @default(PENDENTE) @map("location_precision")
  locationNotes String? @map("location_notes") @db.Text
  placeName     String?  @map("place_name")
  geocodingStatus DevelopmentGeocodingStatus @default(PENDING) @map("geocoding_status")
  geocodingConfidence Decimal? @map("geocoding_confidence") @db.Decimal(6, 4)
  polygonSource String?  @map("polygon_source")
  locationVerifiedAt DateTime? @map("location_verified_at")
  latitude      Decimal? @db.Decimal(10, 7)
  longitude     Decimal? @db.Decimal(10, 7)
  placeId       String?
  polygonCoordinates Json?
  // URL absoluta (Cloudinary/CDN) ou caminho relativo, ex.: /uploads/loteamentos/foto.jpg
  coverImage    String?
  coverImageAlt String?
  coverPublicId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  properties  Property[]
  blocks      Block[]
  instagramAdSuggestions InstagramAdSuggestion[]
  marketingCampaigns     MarketingCampaign[]
  nearbyPlaces DevelopmentNearbyPlace[]

  @@index([city])
  @@index([name])
  @@index([geocodingStatus])
}

/// POIs próximos ao loteamento (cache; fonte típica Overpass/OSM).
model DevelopmentNearbyPlace {
  id                   String   @id @default(cuid())
  developmentId        String   @map("development_id")
  name                 String
  category             String
  subcategory          String?
  latitude             Decimal  @db.Decimal(10, 7)
  longitude            Decimal  @db.Decimal(10, 7)
  shortAddress         String?  @map("short_address")
  source               String   @default("overpass")
  sourceOsmId          String?  @map("source_osm_id")
  searchRadiusMeters   Int      @default(3000) @map("search_radius_meters")
  distanceMeters       Int?     @map("distance_meters")
  travelTimeMinutes    Int?     @map("travel_time_minutes")
  travelMode           String   @default("driving") @map("travel_mode")
  routeSource          String?  @map("route_source")
  fetchedAt            DateTime @default(now()) @map("fetched_at")
  updatedAt            DateTime @updatedAt

  development Development @relation(fields: [developmentId], references: [id], onDelete: Cascade)

  @@index([developmentId])
  @@index([category])
  @@unique([developmentId, source, sourceOsmId, travelMode, searchRadiusMeters])
}

model Block {
  id             String   @id @default(cuid())
  name           String
  developmentId  String
  createdAt      DateTime @default(now())
  updatedAt     DateTime @updatedAt

  development    Development @relation(fields: [developmentId], references: [id], onDelete: Cascade)
  lots           Lot[]

  @@index([developmentId])
}

model Lot {
  id                     String         @id @default(cuid())
  blockId                String
  number                 String
  area                   Decimal?       @db.Decimal(10, 2)
  price                  Decimal?       @db.Decimal(12, 2)
  status                 PropertyStatus @default(DISPONIVEL)
  viewCount              Int            @default(0)
  contactCount           Int            @default(0)
  scheduledVisitsCount   Int            @default(0)
  proposalsCount         Int            @default(0)
  availableSince         DateTime?
  manualHighlight        Boolean        @default(false)
  saleScore              Decimal?       @db.Decimal(5, 2)
  saleClassification     String?
  saleScoreReason        String?        @db.Text
  scoredAt               DateTime?
  latitude               Decimal?       @db.Decimal(10, 7)
  longitude              Decimal?       @db.Decimal(10, 7)
  polygonCoordinates     Json?
  mapLabel               String?
  referencePoint         String?
  streetFront            String?
  geoStatus              LotGeoStatus   @default(SEM_LOCALIZACAO)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  block       Block    @relation(fields: [blockId], references: [id], onDelete: Cascade)
  leads       Lead[]
  visits      Visit[]
  aiMessageSuggestions AiMessageSuggestion[]
  instagramAdSuggestions InstagramAdSuggestion[]
  marketingCampaigns     MarketingCampaign[]
  simulations            Simulation[]

  @@index([blockId])
  @@index([status])
  @@index([saleScore])
  @@index([geoStatus])
}

model AiMessageSuggestion {
  id            String                 @id @default(cuid())
  userId        String
  leadId        String?
  lotId         String?
  messageType   AiSuggestionMessageType
  tone          AiSuggestionTone
  message       String                 @db.Text
  justification String                 @db.Text
  createdAt     DateTime               @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead Lead? @relation(fields: [leadId], references: [id], onDelete: Cascade)
  lot  Lot?  @relation(fields: [lotId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([lotId])
  @@index([userId])
  @@index([createdAt])
}

model InstagramAdSuggestion {
  id              String                 @id @default(cuid())
  userId          String
  lotId           String?
  developmentId   String?
  contentType     InstagramContentType
  objective       InstagramAdObjective
  toneRequested   InstagramAdTone?
  strategicNote   String                 @db.Text
  payloadJson     Json
  createdAt       DateTime               @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lot         Lot?         @relation(fields: [lotId], references: [id], onDelete: SetNull)
  development Development? @relation(fields: [developmentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([lotId])
  @@index([developmentId])
  @@index([createdAt])
}

model MarketingCampaign {
  id                 String                   @id @default(cuid())
  userId             String                   @map("user_id")
  developmentId      String                   @map("development_id")
  lotId              String?                  @map("lot_id")
  title              String
  objective          InstagramAdObjective     @default(AUTO)
  status             MarketingCampaignStatus  @default(DRAFT)
  primaryContentType InstagramContentType     @default(FEED) @map("primary_content_type")
  packJson           Json?                    @map("pack_json")
  lastGeneratedAt    DateTime?                @map("last_generated_at")
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")

  user         User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  development  Development                 @relation(fields: [developmentId], references: [id], onDelete: Cascade)
  lot          Lot?                        @relation(fields: [lotId], references: [id], onDelete: SetNull)
  assets       CampaignAsset[]
  targets      CampaignPublicationTarget[]
  copies       CampaignCopy[]
  aiImageJobs  AiImageGenerationJob[]

  @@index([userId])
  @@index([developmentId])
  @@index([lotId])
  @@index([createdAt])
  @@map("marketing_campaigns")
}

model CampaignAsset {
  id         String              @id @default(cuid())
  campaignId String              @map("campaign_id")
  kind       CampaignAssetKind
  origin     CampaignAssetOrigin
  url        String
  publicId   String?             @map("public_id")
  fileName   String?             @map("file_name")
  mimeType   String?             @map("mime_type")
  isPrimary  Boolean             @default(false) @map("is_primary")
  sortOrder  Int                 @default(0) @map("sort_order")
  createdAt  DateTime            @default(now()) @map("created_at")

  campaign MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("campaign_assets")
}

model CampaignPublicationTarget {
  id                  String                  @id @default(cuid())
  campaignId          String                  @map("campaign_id")
  platform            PublicationPlatform
  aspectHint          String?                 @map("aspect_hint")
  status              PublicationTargetStatus @default(EXPORT_PENDING)
  publishedAt         DateTime?               @map("published_at")
  externalPostId      String?                 @map("external_post_id")
  externalContainerId String?                 @map("external_container_id")
  publishError        String?                 @map("publish_error") @db.Text
  rawResponseJson     Json?                   @map("raw_response_json")
  createdAt           DateTime                @default(now()) @map("created_at")
  updatedAt           DateTime                @updatedAt @map("updated_at")

  campaign MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, platform])
  @@map("campaign_publication_targets")
}

model SocialConnection {
  id                 String                 @id @default(cuid())
  userId             String                 @map("user_id")
  provider           SocialProvider
  accountLabel       String?                @map("account_label")
  facebookPageId     String                 @map("facebook_page_id")
  facebookPageName   String?                @map("facebook_page_name")
  instagramUserId    String?                @map("instagram_user_id")
  instagramUsername  String?                @map("instagram_username")
  accessTokenEnc     String                 @map("access_token_enc") @db.Text
  tokenExpiresAt     DateTime?              @map("token_expires_at")
  status             SocialConnectionStatus @default(ACTIVE)
  metadataJson       Json?                  @map("metadata_json")
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, facebookPageId])
  @@index([userId])
  @@map("social_connections")
}

model CampaignCopy {
  id               String              @id @default(cuid())
  campaignId       String              @map("campaign_id")
  platform         PublicationPlatform
  title            String?             @db.Text
  caption          String?             @db.Text
  shortCaption     String?             @map("short_caption") @db.Text
  cta              String?             @db.Text
  hashtags         String?             @db.Text
  reelScriptJson   Json?               @map("reel_script_json")
  professionalTone String?             @map("professional_tone") @db.Text
  persuasiveTone   String?             @map("persuasive_tone") @db.Text
  directTone       String?             @map("direct_tone") @db.Text
  justification    String?             @db.Text
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  campaign MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, platform])
  @@map("campaign_copies")
}

model AiImageGenerationJob {
  id             String           @id @default(cuid())
  campaignId     String           @map("campaign_id")
  provider       String
  prompt         String           @db.Text
  status         AiImageJobStatus @default(PENDING)
  resultUrl      String?          @map("result_url")
  resultPublicId String?          @map("result_public_id")
  errorMessage   String?          @map("error_message") @db.Text
  variationIndex Int?             @map("variation_index")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  campaign MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("ai_image_generation_jobs")
}

model Visit {
  id          String      @id @default(cuid())
  propertyId  String?
  lotId       String?
  userId      String
  clientId    String?
  leadId      String?
  scheduledAt DateTime
  status      VisitStatus  @default(AGENDADA)
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  property    Property?   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  lot         Lot?        @relation(fields: [lotId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  client      Client?     @relation(fields: [clientId], references: [id], onDelete: SetNull)
  lead        Lead?       @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([propertyId])
  @@index([lotId])
  @@index([userId])
  @@index([clientId])
  @@index([leadId])
  @@index([scheduledAt])
}

model Client {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  brokerId  String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  broker    User     @relation("BrokerClients", fields: [brokerId], references: [id], onDelete: Cascade)
  visits    Visit[]
  leads     Lead[]
  simulations Simulation[]
  proposals   Proposal[]
  contracts   Contract[]
  sales       Sale[]

  @@index([brokerId])
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
}

model Lead {
  id               String     @id @default(cuid())
  propertyId       String?
  lotId            String?
  userId           String?
  clientId         String?
  name             String
  email            String
  phone            String?
  message          String?
  notes            String?
  source           String?
  leadSource       String?
  status           LeadStatus @default(PROSPECCAO)
  isHot            Boolean    @default(false)
  interactionCount Int        @default(0)
  leadLastInteractionAt DateTime?
  closingScore            Decimal?  @db.Decimal(5, 2)
  closingPrediction       String?
  closingReason           String?   @db.Text
  closingInterestLevel    String?
  closingPriorityLevel    String?
  closingNextAction       String?   @db.Text
  closingPositiveFactors  Json?
  closingRiskFactors      Json?
  closingScoreUpdatedAt   DateTime?
  previousClosingScore    Decimal?  @db.Decimal(5, 2)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @default(now()) @updatedAt

  property     Property?          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  lot          Lot?               @relation(fields: [lotId], references: [id], onDelete: SetNull)
  user         User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  client       Client?            @relation(fields: [clientId], references: [id], onDelete: SetNull)
  visits       Visit[]
  interactions LeadInteraction[]
  aiMessageSuggestions AiMessageSuggestion[]
  predictionSnapshots LeadPredictionSnapshot[]

  @@index([propertyId])
  @@index([lotId])
  @@index([userId])
  @@index([status])
  @@index([closingScore])
}

model LeadPredictionSnapshot {
  id                    String   @id @default(cuid())
  leadId                String
  closingScore          Decimal  @db.Decimal(5, 2)
  closingPrediction     String
  closingReason         String   @db.Text
  nextRecommendedAction String   @db.Text
  factorsJson           Json
  previousScore         Decimal? @db.Decimal(5, 2)
  createdAt             DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([createdAt])
}

model LeadInteraction {
  id        String   @id @default(cuid())
  leadId    String
  userId    String?
  type      String
  body      String?
  createdAt DateTime @default(now())

  lead Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([userId])
}

model Payment {
  id          String        @id @default(cuid())
  userId      String
  description String
  totalAmount Decimal       @db.Decimal(12, 2)
  status      PaymentStatus @default(PENDENTE)
  dueDate     DateTime?
  saleId      String?       @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  installments Installment[]
  sale         Sale?         @relation(fields: [saleId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model Installment {
  id          String        @id @default(cuid())
  paymentId   String
  amount      Decimal       @db.Decimal(12, 2)
  dueDate     DateTime
  paidAt      DateTime?
  status      PaymentStatus @default(PENDENTE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  payment     Payment       @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  action      String
  entity      String
  entityId    String?
  metadata    Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entity, entityId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
}

model Bank {
  id          String   @id @default(cuid())
  name        String
  monthlyRate Decimal  @db.Decimal(10, 8)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
}

model Simulation {
  id             String   @id @default(cuid())
  userId         String
  clientName     String
  cpf            String
  clientPhone    String?
  income         Decimal  @db.Decimal(12, 2)
  propertyValue  Decimal  @db.Decimal(14, 2)
  downPayment    Decimal  @db.Decimal(14, 2)
  financedAmount Decimal  @db.Decimal(14, 2)
  age            Int?
  maritalStatus  String?
  dependents     Int      @default(0)
  hasFGTS        Boolean  @default(false)
  fgtsAmount     Decimal  @default(0) @db.Decimal(14, 2)
  clientId       String?
  propertyId     String?
  lotId          String?
  metadata       Json?
  createdAt      DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  client   Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  lot      Lot?      @relation(fields: [lotId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@index([lotId])
}

model Contract {
  id               String         @id @default(cuid())
  proposalId       String         @unique
  userId           String
  clientId         String?
  propertyId       String?
  totalValue       Decimal        @db.Decimal(14, 2)
  downPayment      Decimal        @db.Decimal(14, 2)
  financedAmount   Decimal        @db.Decimal(14, 2)
  bankName         String
  installmentValue Decimal        @db.Decimal(12, 2)
  months           Int
  contractText     String         @db.Text
  clientCpf        String?
  status           ContractStatus @default(DRAFT)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  client   Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  sale     Sale?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Sale {
  id               String     @id @default(cuid())
  contractId       String     @unique
  proposalId       String     @unique
  userId           String
  clientId         String?
  propertyId       String?
  totalValue       Decimal    @db.Decimal(14, 2)
  downPayment      Decimal    @db.Decimal(14, 2)
  financedAmount   Decimal    @db.Decimal(14, 2)
  bankName         String
  installmentValue Decimal    @db.Decimal(12, 2)
  months           Int
  status           SaleStatus @default(CONFIRMED)
  soldAt           DateTime   @default(now())
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  contract Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  proposal Proposal  @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  client   Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  payment  Payment?

  @@index([userId])
  @@index([soldAt])
}

model Proposal {
  id          String         @id @default(cuid())
  userId      String
  clientId    String?
  propertyId  String?
  bank        String
  installment Decimal        @db.Decimal(12, 2)
  months      Int
  downPayment Decimal        @db.Decimal(14, 2)
  status      ProposalStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  client   Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  contract Contract?
  sale     Sale?

  @@index([userId])
  @@index([clientId])
  @@index([propertyId])
  @@index([status])
  @@index([createdAt])
}
