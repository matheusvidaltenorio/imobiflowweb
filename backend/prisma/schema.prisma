model SocialConnection {
  id                 String                 @id @default(cuid())
  userId             String                 @map("user_id")
  provider           SocialProvider
  accountLabel       String?                @map("account_label")
  facebookPageId     String                 @map("facebook_page_id")
  facebookPageName   String?                @map("facebook_page_name")
  instagramUserId    String?                @map("instagram_user_id")
  instagramUsername  String?                @map("instagram_username")
  accessTokenEnc     String                 @map("access_token_enc") @db.Text
  tokenExpiresAt     DateTime?              @map("token_expires_at")
  status             SocialConnectionStatus @default(ACTIVE)
  metadataJson       Json?                  @map("metadata_json")
  /// Última sincronização bem-sucedida com a Graph (OAuth / refresh).
  lastSyncAt         DateTime?              @map("last_sync_at")
  /// Último erro amigável (não expor token).
  lastError          String?                @map("last_error") @db.Text
  /// Escopos concedidos na última autorização (string separada por vírgula).
  grantedScopes      String?                @map("granted_scopes") @db.Text
  /// Página usada por padrão ao publicar (uma por usuário recomendada).
  isDefault          Boolean                @default(false) @map("is_default")
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs SocialIntegrationLog[]

  @@unique([userId, facebookPageId])
  @@index([userId])
  @@index([userId, isDefault])
  @@map("social_connections")
}

/// Histórico de integração Meta (auditoria; sem segredos).
